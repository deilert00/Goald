{
  "name": "goald",
  "version": "1.0.0",
  "private": true,
  "description": "Behavior-based end-to-end testing for Goald",
  "scripts": {
    "test:e2e": "cucumber-js --config cucumber.js",
    "test:e2e:headed": "cross-env HEADLESS=false cucumber-js --config cucumber.js",
    "test:e2e:report": "cucumber-js --config cucumber.js --format progress-bar --format html:reports/cucumber-report.html"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "cross-env": "^7.0.3",
    "playwright": "^1.52.0"
  }
}
